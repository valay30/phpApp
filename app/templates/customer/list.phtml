<?php include 'app/templates/menu.phtml'; ?>

<h2>Customer List</h2>
<a href="index.php?c=customer&a=edit">Add Customer</a>
<br><br>

<table border="1" width="100%">
    <tr>
        <th>ID</th>
        <th>Customer Group ID</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Status</th>
        <th>Created Date</th>
        <th>Updated Date</th>
        <th>Actions</th>
    </tr>
    <?php if (!empty($data)): ?>
        <?php foreach ($data as $row): ?>
            <tr>
                <td><?php echo $row->customer_id; ?></td>
                <td><?php echo $row->customer_group_id; ?></td>
                <td><?php echo $row->first_name; ?></td>
                <td><?php echo $row->last_name; ?></td>
                <td><?php echo $row->email; ?></td>
                <td><?php echo $row->phone; ?></td>
                <td><?php echo $row->status == 1 ? 'Enabled' : 'Disabled'; ?></td>
                <td><?php echo $row->created_date; ?></td>
                <td><?php echo $row->updated_date; ?></td>
                <td>
                    <a href="index.php?c=customer&a=edit&id=<?php echo $row->customer_id; ?>">Edit</a> |
                    <a href="index.php?c=customer&a=delete&id=<?php echo $row->customer_id; ?>">Delete</a>
